print("[Optimizer] Optimizing breakables...")

local breakables = workspace.__THINGS:WaitForChild("Breakables")
local processed = {}

local removedMeshes = 0
local removedClickDetectors = 0
local removedEffects = 0

local function optimizeModel(model)
	if not model:IsA("Model") or processed[model] then
		return
	end

	processed[model] = true

	for _, obj in ipairs(model:GetDescendants()) do
		if obj:IsA("MeshPart") then
			obj:Destroy()
			removedMeshes += 1

		elseif obj:IsA("ClickDetector") then
			obj:Destroy()
			removedClickDetectors += 1

		elseif obj:IsA("ParticleEmitter")
			or obj:IsA("Beam")
			or obj:IsA("Trail")
			or obj:IsA("Highlight")
			or obj:IsA("PointLight")
			or obj:IsA("SurfaceLight")
			or obj:IsA("SpotLight")
			or obj:IsA("Fire")
			or obj:IsA("Smoke")
			or obj:IsA("Sparkles")
			or obj:IsA("Decal")
			or obj:IsA("Texture")
			or obj:IsA("Mesh") then

			obj:Destroy()
			removedEffects += 1
		end
	end

	-- Remove anything added later
	model.DescendantAdded:Connect(function(obj)
		task.defer(function()
			if not obj.Parent then
				return
			end

			if obj:IsA("MeshPart") then
				obj:Destroy()

			elseif obj:IsA("ClickDetector") then
				obj:Destroy()

			elseif obj:IsA("ParticleEmitter")
				or obj:IsA("Beam")
				or obj:IsA("Trail")
				or obj:IsA("Highlight")
				or obj:IsA("PointLight")
				or obj:IsA("SurfaceLight")
				or obj:IsA("SpotLight")
				or obj:IsA("Fire")
				or obj:IsA("Smoke")
				or obj:IsA("Sparkles")
				or obj:IsA("Decal")
				or obj:IsA("Texture")
				or obj:IsA("Mesh") then

				obj:Destroy()
			end
		end)
	end)
end

-- Existing breakables
for _, model in ipairs(breakables:GetChildren()) do
	optimizeModel(model)
end

-- Future breakables
breakables.ChildAdded:Connect(function(model)
	task.defer(function()
		optimizeModel(model)
	end)
end)

print(string.format(
	"[Optimizer] Done!\nMeshParts: %d\nClickDetectors: %d\nEffects: %d",
	removedMeshes,
	removedClickDetectors,
	removedEffects
))
