local Players = game:GetService("Players")

local player = Players.LocalPlayer

-- Area bounds
local MIN_X = 1347
local MAX_X = 1500
local MIN_Z = -32056
local MAX_Z = -31950

local Y = 16.24
local STEP = 10
local STEP_Z = 30
local WAIT = 0.01

-- Base/Return position
local BASE_POS = Vector3.new(1346.9329833984375, 16.239492416381836, -32054.794921875)

local running = false

local function getHRP()
    local character = player.Character or player.CharacterAdded:Wait()
    return character:WaitForChild("HumanoidRootPart")
end

local function walkTo(position)
    local hrp = getHRP()
    local humanoid = hrp.Parent:WaitForChild("Humanoid")
    humanoid.WalkSpeed = 100
    humanoid:MoveTo(position)
    humanoid.MoveToFinished:Wait()
end

-- Get Cost label reference
local costLabel = workspace:FindFirstChild("__THINGS"):FindFirstChild("__INSTANCE_CONTAINER"):FindFirstChild("Active"):FindFirstChild("SoccerEvent"):FindFirstChild("INTERACT"):FindFirstChild("Yeet Event Sign"):FindFirstChild("Main"):FindFirstChild("SurfaceGui"):FindFirstChild("Panel"):FindFirstChild("Amount"):FindFirstChild("Cost")

-- GUI
local gui = Instance.new("ScreenGui")
gui.Name = "OrbFarm"
gui.ResetOnSpawn = false
gui.Parent = game.CoreGui

local btn = Instance.new("TextButton")
btn.Size = UDim2.fromOffset(170,45)
