--// TOGGLES
local REMOVE_PARTS_LOD           = true
local REMOVE_DECORATION_FOLDERS  = true
local REMOVE_MESHPARTS           = true
local REMOVE_DECORATION_MODELS   = true
local REMOVE_PARTS               = true -- Hide/delete loose Parts & UnionOperations
local REMOVE_EFFECTS             = true
local REMOVE_TEXTURES            = true
local REMOVE_LIGHTS              = true
local HIDE_INSTEAD_OF_DESTROY    = false -- safer

local map = workspace:FindFirstChild("Map") or workspace:FindFirstChild("Map2") or workspace:FindFirstChild("Map3") or workspace:FindFirstChild("Map4")

if not map then
	error("Map folder not found")
end

local REMOVE_FOLDERS = {
	Foilage = true,
	Foliage = true,
	Bush = true,
	Bushes = true,
	Hills = true,
	Hill = true,
	Rocks = true,
	Rock = true,
	Mushroom = true,
	JungleStuff = true,
	Waterfall = true,
	Pack = true,
	Water = true,
	Balloons = true,
	Easterdecor = true,
	VIP = true,
	Cat = true,
}

local MODEL_KEYWORDS = {
	"Tree",
	"Evergreen",
	"Palm",
	"Sakura",
	"Bush",
	"Flower",
	"Grass",
	"Crystal",
	"Rock",
	"Water",
	"Scaffold",
	"Windmill",
	"Fountain",
	"Balloon",
	"StarFish",
	"CreepyHouse",
	"Shinto",
	"Mushroom",
}

local EFFECTS = {
	ParticleEmitter=true,
	Beam=true,
	Trail=true,
	Smoke=true,
	Fire=true,
	Sparkles=true,
	Explosion=true,
	Highlight=true,
}

local LIGHTS = {
	PointLight=true,
	SpotLight=true,
	SurfaceLight=true,
}

local function remove(obj)
	if HIDE_INSTEAD_OF_DESTROY then
		if obj:IsA("BasePart") then
			obj.Transparency = 1
			obj.CastShadow = false
			obj.CanCollide = false
		else
			obj.Parent = nil
		end
	else
		obj:Destroy()
	end
end

for _, zone in ipairs(map:GetChildren()) do

	------------------------------------------------
	-- Stage 1 : Remove PARTS_LOD
	------------------------------------------------
	if REMOVE_PARTS_LOD then
		local lod = zone:FindFirstChild("PARTS_LOD")
		if lod then
			remove(lod)
		end
	end

	local parts = zone:FindFirstChild("PARTS")
	if not parts then
		continue
	end

	------------------------------------------------
	-- Stage 2 : Remove decoration folders
	------------------------------------------------
	if REMOVE_DECORATION_FOLDERS then
		for _, obj in ipairs(parts:GetChildren()) do
			if REMOVE_FOLDERS[obj.Name] then
				remove(obj)
			end
		end
	end

	------------------------------------------------
	-- Stage 3+
	------------------------------------------------
	for _, obj in ipairs(parts:GetDescendants()) do

		-- Meshes
		if REMOVE_MESHPARTS and obj:IsA("MeshPart") then
			remove(obj)

		-- Decoration models
		elseif REMOVE_DECORATION_MODELS and (obj:IsA("Model") or obj:IsA("Folder")) then
			for _, keyword in ipairs(MODEL_KEYWORDS) do
				if obj.Name:find(keyword,1,true) then
					remove(obj)
					break
				end
			end

		-- Loose map geometry
		elseif REMOVE_PARTS and (
			obj:IsA("Part") or
			obj:IsA("UnionOperation") or
			obj:IsA("WedgePart")
		) then
			if obj.Name ~= "Path" then
				remove(obj)
			end

		-- Effects
		elseif REMOVE_EFFECTS and EFFECTS[obj.ClassName] then
			remove(obj)

		-- Lights
		elseif REMOVE_LIGHTS and LIGHTS[obj.ClassName] then
			remove(obj)

		-- Decals/Textures
		elseif REMOVE_TEXTURES and (
			obj:IsA("Texture") or
			obj:IsA("Decal")
		) then
			remove(obj)
		end
	end
end

setclipboard("Map optimization finished.")
