print("[Optimizer] Optimizing eggs...")

local things = workspace:WaitForChild("__THINGS")

local folders = {
    things:FindFirstChild("CustomEggs"),
    things:FindFirstChild("ZoneEggs"),
    things:FindFirstChild("Eggs"),
    things:FindFirstChild("RenderedEggs")
}

local removeClasses = {
    Part = true,
    MeshPart = true,
    SurfaceLight = true,
    SurfaceGui = true,
    BillboardGui = true,
    ImageLabel = true,
    TextLabel = true,
    TextButton = true,
    Frame = true,
    UIStroke = true,
    UICorner = true,
    UIGradient = true,
    UIPadding = true,
    UIScale = true,
    UIAspectRatioConstraint = true,
    UIListLayout = true,
    SurfaceAppearance = true,
    Highlight = true,
    ParticleEmitter = true
}

local removed = {}
local processed = {}

for class in pairs(removeClasses) do
    removed[class] = 0
end

local function optimize(folder)
    if not folder then
        return
    end

    for _, obj in ipairs(folder:GetDescendants()) do
        if not processed[obj] then
            processed[obj] = true

            if removeClasses[obj.ClassName] then
                removed[obj.ClassName] += 1
                obj:Destroy()
            end
        end
    end

    folder.DescendantAdded:Connect(function(obj)
        task.defer(function()
            if obj.Parent and removeClasses[obj.ClassName] then
                obj:Destroy()
            end
        end)
    end)
end

for _, folder in ipairs(folders) do
    optimize(folder)
end

local out = {"[Egg Optimizer]"}
for class, count in pairs(removed) do
    table.insert(out, ("%s: %d"):format(class, count))
end

print(table.concat(out, "\n"))
